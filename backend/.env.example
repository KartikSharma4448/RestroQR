# Database
DATABASE_URL=postgresql://user:password@localhost:5432/restroqr

# Test Database (used by test suite)
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/restroqr_test

# Authentication
JWT_SECRET=your-jwt-secret-here

# Cloudinary (Image Storage)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Table Token Encryption (32-byte hex key or passphrase)
TABLE_TOKEN_SECRET=your-table-token-secret-here-must-be-32-bytes

# Server
PORT=3000
