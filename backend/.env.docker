# Docker-specific environment variables
# Used when running with docker-compose

# Database (points to the docker postgres service)
DATABASE_URL=postgresql://restroqr:restroqr_secret@postgres:5432/restroqr

# Authentication
JWT_SECRET=change-this-to-a-secure-random-secret

# Cloudinary (Image Storage)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Server
PORT=3000
NODE_ENV=production
